import type { OutlinerNode } from '../db/schema';

interface BreadcrumbsProps {
  path: OutlinerNode[];
  onNavigate: (nodeId: string) => void;
}

export function Breadcrumbs({ path, onNavigate }: BreadcrumbsProps) {
  if (path.length <= 1) return null;

  return (
    <nav className="breadcrumbs">
      {path.map((node, i) => (
        <span key={node.id} className="breadcrumb-item">
          <span
            className={`breadcrumb-label ${i === path.length - 1 ? 'current' : ''}`}
            onClick={() => i !== path.length - 1 && onNavigate(node.id)}
          >
            {node.content || 'Untitled'}
          </span>
          {i < path.length - 1 && <span className="breadcrumb-separator">/</span>}
        </span>
      ))}
    </nav>
  );
}
